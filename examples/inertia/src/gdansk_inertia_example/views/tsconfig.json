{
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["DOM", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "paths": {
      "@types/gdansk": ["./types/gdansk/index"],
      "@types/gdansk/*": ["./types/gdansk/*"]
    },
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022",
    "types": ["node", "vite/client"]
  },
  "include": ["types", "app", "vite-env.d.ts", "vite.config.ts"]
}
