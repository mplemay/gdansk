{
  "compilerOptions": {
    "rootDir": "src",
    "noEmitOnError": true,
    "lib": ["ES2023", "DOM"],
    "target": "ES2023",
    "types": ["node"],
    "declaration": true,
    "declarationDir": "types",
    "emitDeclarationOnly": true,
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true
  },
  "include": ["src/**/*.ts"]
}
