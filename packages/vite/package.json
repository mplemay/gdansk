    "react-dom": "^19.0.0",
    "vite": "^8.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.13",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "esbuild": "^0.27.3",
    "esbuild-node-externals": "^1.20.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.4",
    "vitest": "^4.1.2"
